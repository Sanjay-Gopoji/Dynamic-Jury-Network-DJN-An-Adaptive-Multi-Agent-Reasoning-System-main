# --- Gemini (Judge | Moderator) ---
GOOGLE_API_KEY="Your API Key"

# --- Ollama Cloud (Jurors) ---
# Put the base URL exactly as your Ollama Cloud endpoint expects (from your txt)
OLLAMA_BASE_URL="https://ollama.com"
OLLAMA_API_KEY="Your API Key"

# --- NVIDIA NIM (Nemotron juror) ---
NVIDIA_NIM_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_API_KEY="Your API Key"

# --- DJN settings ---
DJN_MAX_ROUNDS=3
DJN_THRESHOLD=0.75
DJN_MIN_IMPROVEMENT=0.05
DJN_STAGNATION_ROUNDS=1
DJN_MIN_OK_JURORS=2

# --- Google OAuth credentials ---
GOOGLE_CLIENT_SECRETS_FILE=credentials.json
GOOGLE_OAUTH_REDIRECT_URI=Your GOOGLE OAUTH REDIRECT URI
